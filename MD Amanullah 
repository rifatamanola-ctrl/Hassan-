<!DOCTYPE html>
<html>
<head>
    <title>SECURITY_SCANNER</title>
    <style>
        body { background-color: #000; color: #0f0; font-family: 'Courier New', monospace; padding: 20px; }
        .container { border: 1px solid #0f0; padding: 20px; max-width: 600px; margin: auto; }
        input { width: 90%; padding: 10px; background: #111; color: #0f0; border: 1px solid #0f0; margin-bottom: 10px; }
        button { background: #0f0; color: #000; border: none; padding: 10px 20px; cursor: pointer; font-weight: bold; margin: 5px; }
        #output { margin-top: 20px; word-break: break-all; border-top: 1px dashed #0f0; padding-top: 10px; }
    </style>
</head>
<body>

<div class="container">
    <h1>[ SYSTEM_CORE_INITIALIZED ]</h1>
    <input type="text" id="target" placeholder="INPUT_TARGET_URL_OR_ID">
    
    <div>
        <button onclick="runScan('PHISHING')">PHISHING_SCAN</button>
        <button onclick="runScan('MALWARE')">MALWARE_SCAN</button>
        <button onclick="runScan('HACK')">HACK_LINK_CHECK</button>
        <button onclick="runScan('DEEP')">DEEP_SCAN</button>
    </div>

    <div id="output">WAITING_FOR_INPUT...</div>
</div>

<script>
function runScan(mode) {
    const target = document.getElementById('target').value.toLowerCase();
    const output = document.getElementById('output');
    
    if (!target) {
        output.innerHTML = "ERROR: NO_INPUT_DETECTED";
        return;
    }

    output.innerHTML = "SCANNING_IN_PROGRESS...";

    const maliciousPatterns = ["phishing", "login-steal", "hack", "virus", "malware", "scam", "bit.ly", "tinyurl"];
    
    setTimeout(() => {
        let isThreat = maliciousPatterns.some(pattern => target.includes(pattern));
        
        if (isThreat) {
            output.innerHTML = "ALERT: THREAT_DETECTED_IN_" + mode + "_SCAN. DO_NOT_PROCEED.";
        } else {
            output.innerHTML = "STATUS: " + mode + "_SCAN_COMPLETE. NO_THREATS_FOUND.";
        }
    }, 1000);
}
</script>

</body>
</html>